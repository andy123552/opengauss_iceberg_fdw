index 0000000000000000000000000000000000000000..121cfef3e2661eee9d79fe08e154d4f1ac87f260
--- /dev/null
+++ b/iceberg-opengauss-build/skills/iceberg-opengauss-builder/scripts/adaptive_build.py
@@ -0,0 +1,289 @@
+#!/usr/bin/env python3
+"""Adaptive build wrapper for the Iceberg + openGauss multi-repo workspace."""
+
+from __future__ import annotations
+
+import argparse
+import datetime as _dt
+import os
+import re
+import shlex
+import subprocess
+import sys
+from pathlib import Path
+from typing import Iterable
+
+
+REPOS = {
+    "opengauss": "openGauss-server-datainfra",
+    "index": "iceberg-index",
+    "bridge": "iceberg-rust-bridge",
+    "fdw": "iceberg_fdw",
+    "catalog": "openGauss-Catalog",
+    "delta": "iceberg_delta",
+}
+
+ALIASES = {
+    "openGauss-server-datainfra": "opengauss",
+    "openGauss-server": "opengauss",
+    "opengauss-server": "opengauss",
+    "iceberg-index": "index",
+    "iceberg-rust-bridge": "bridge",
+    "iceberg_fdw": "fdw",
+    "iceberg-fdw": "fdw",
+    "openGauss-Catalog": "catalog",
+    "opengauss-catalog": "catalog",
+    "iceberg_delta": "delta",
+    "iceberg-delta": "delta",
+}
+
+COMPONENT_TARGETS = {
+    "opengauss": ["opengauss", "verify-opengauss"],
+    "index": ["index"],
+    "bridge": ["bridge", "verify-bridge"],
+    "fdw": ["fdw", "verify-fdw"],
+    "catalog": ["catalog", "verify-catalog"],
+    "delta": ["delta", "verify-delta"],
+    "assemble": ["assemble", "verify-all"],
+    "all": ["all"],
+    "verify": ["verify-all"],
+    "verify-all": ["verify-all"],
+}
+
+DIRECT_TARGETS = {
+    "bridge-build",
+    "bridge-install",
+    "fdw-build",
+    "fdw-install",
+    "catalog-build",
+    "catalog-install",
+    "delta-build",
+    "delta-install",
+    "verify-opengauss",
+    "verify-bridge",
+    "verify-fdw",
+    "verify-catalog",
+    "verify-delta",
+}
+
+INTERFACE_RE = re.compile(
+    r"(abi|interface|bridge|catalog|fdw|foreign|extension|\.h$|Cargo\.toml$|Cargo\.lock$)",
+    re.IGNORECASE,
+)
+
+ERROR_RE = re.compile(
+    r"(error:|fatal:|CMake Error|undefined reference|No such file|cannot find|"
+    r"recipe for target|collect2: error|Traceback|panic|failed|make(\[[0-9]+\])?: \*\*\*)",
+    re.IGNORECASE,
+)
+
+
+def run_capture(cmd: list[str], cwd: Path) -> subprocess.CompletedProcess[str]:
+    return subprocess.run(cmd, cwd=str(cwd), text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
+
+
+def split_components(value: str | None) -> list[str]:
+    if not value:
+        return []
+    parts: list[str] = []
+    for raw in value.replace(",", " ").split():
+        item = raw.strip()
+        if item:
+            parts.append(item)
+    return parts
+
+
+def normalize_component(name: str) -> str:
+    return ALIASES.get(name, name)
+
+
+def add_unique(targets: list[str], additions: Iterable[str]) -> None:
+    for target in additions:
+        if target not in targets:
+            targets.append(target)
+
+
+def expand_requested(items: list[str]) -> list[str]:
+    targets: list[str] = []
+    unknown: list[str] = []
+    for item in items:
+        key = normalize_component(item)
+        if key in COMPONENT_TARGETS:
+            add_unique(targets, COMPONENT_TARGETS[key])
+        elif key in DIRECT_TARGETS:
+            add_unique(targets, [key])
+        else:
+            unknown.append(item)
+    if unknown:
+        raise SystemExit(f"Unknown component/repository: {', '.join(unknown)}")
+    return targets
+
+
+def repo_changes(repo: Path, base_ref: str | None, include_untracked: bool) -> list[str]:
+    if not repo.exists() or not (repo / ".git").exists():
+        return []
+
+    changes: list[str] = []
+    if base_ref:
+        diff = run_capture(["git", "diff", "--name-only", f"{base_ref}...HEAD"], repo)
+        if diff.returncode == 0:
+            changes.extend(line for line in diff.stdout.splitlines() if line)
+
+    status = run_capture(["git", "status", "--short"], repo)
+    if status.returncode == 0:
+        for line in status.stdout.splitlines():
+            if not line:
+                continue
+            code = line[:2]
+            path = line[3:].strip()
+            if " -> " in path:
+                path = path.split(" -> ", 1)[1]
+            if code == "??" and not include_untracked:
+                continue
+            if path:
+                changes.append(path)
+
+    return sorted(set(changes))
+
+
+def infer_targets(root: Path, base_ref: str | None, include_untracked: bool) -> tuple[list[str], dict[str, list[str]]]:
+    changed: dict[str, list[str]] = {}
+    interface_change = False
+    targets: list[str] = []
+
+    for component, dirname in REPOS.items():
+        paths = repo_changes(root / dirname, base_ref, include_untracked)
+        if not paths:
+            continue
+        changed[component] = paths
+        if any(INTERFACE_RE.search(path) for path in paths):
+            interface_change = True
+        add_unique(targets, COMPONENT_TARGETS[component])
+
+    if interface_change and changed:
+        targets = []
+        add_unique(targets, ["index", "bridge", "fdw", "catalog", "delta", "verify-all"])
+
+    return targets, changed
+
+
+def read_error_excerpt(log_path: Path, max_lines: int = 180) -> str:
+    try:
+        lines = log_path.read_text(errors="replace").splitlines()
+    except OSError as exc:
+        return f"Could not read log: {exc}"
+
+    matched: list[int] = [idx for idx, line in enumerate(lines) if ERROR_RE.search(line)]
+    selected: list[str] = []
+    seen: set[int] = set()
+
+    for idx in matched[:20]:
+        start = max(0, idx - 3)
+        end = min(len(lines), idx + 8)
+        for line_no in range(start, end):
+            if line_no in seen:
+                continue
+            seen.add(line_no)
+            selected.append(f"{line_no + 1}: {lines[line_no]}")
+            if len(selected) >= max_lines:
+                return "\n".join(selected)
+
+    if selected:
+        return "\n".join(selected)
+
+    tail = lines[-80:]
+    return "\n".join(f"{len(lines) - len(tail) + idx + 1}: {line}" for idx, line in enumerate(tail))
+
+
+def default_root() -> Path:
+    cwd = Path.cwd().resolve()
+    if (cwd / "openGauss-server-datainfra" / "iceberg-opengauss-build").exists():
+        return cwd
+    if cwd.name == "openGauss-server-datainfra" and (cwd / "iceberg-opengauss-build").exists():
+        return cwd.parent
+    for parent in cwd.parents:
+        if (parent / "openGauss-server-datainfra" / "iceberg-opengauss-build").exists():
+            return parent
+    return cwd
+
+
+def summarize_changes(changed: dict[str, list[str]]) -> list[str]:
+    summary: list[str] = []
+    for component, paths in changed.items():
+        sample = ", ".join(paths[:5])
+        more = "" if len(paths) <= 5 else f" (+{len(paths) - 5} more)"
+        summary.append(f"  - {REPOS[component]}: {len(paths)} changed file(s): {sample}{more}")
+    return summary
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--root", default=None, help="Multi-repository root. Defaults to auto-detected workspace root.")
+    parser.add_argument("--opengauss-repo", default=None, help="Path to openGauss-server-datainfra.")
+    parser.add_argument("--components", default=None, help="Comma/space-separated components or repository names to build.")
+    parser.add_argument("--base-ref", default=None, help="Optional git ref for committed-change detection, e.g. origin/main.")
+    parser.add_argument("--include-untracked", action="store_true", help="Include untracked files when inferring changed repositories.")
+    parser.add_argument("--log-dir", default=None, help="Directory for full build logs.")
+    parser.add_argument("--dry-run", action="store_true", help="Print inferred targets without compiling.")
+    args = parser.parse_args()
+
+    root = Path(args.root).expanduser().resolve() if args.root else default_root()
+    opengauss_repo = Path(args.opengauss_repo).expanduser().resolve() if args.opengauss_repo else root / "openGauss-server-datainfra"
+    build_script = opengauss_repo / "iceberg-opengauss-build" / "build-component.sh"
+    if not build_script.exists():
+        print(f"ERROR: build script not found: {build_script}", file=sys.stderr)
+        return 2
+
+    requested = split_components(args.components)
+    changed: dict[str, list[str]] = {}
+    if requested:
+        targets = expand_requested(requested)
+    else:
+        targets, changed = infer_targets(root, args.base_ref, args.include_untracked)
+        if not targets:
+            targets = ["assemble", "verify-all"]
+
+    log_dir = Path(args.log_dir).expanduser().resolve() if args.log_dir else opengauss_repo / "iceberg-opengauss-build" / "logs" / "adaptive"
+    timestamp = _dt.datetime.now().strftime("%Y%m%d-%H%M%S")
+    log_path = log_dir / f"adaptive-build-{timestamp}.log"
+
+    print(f"Workspace root: {root}")
+    print(f"openGauss repo: {opengauss_repo}")
+    if changed:
+        print("Detected changes:")
+        print("\n".join(summarize_changes(changed)))
+    elif requested:
+        print(f"Requested components: {', '.join(requested)}")
+    else:
+        print("No repository changes detected; defaulting to assemble + verify-all.")
+    print(f"Selected targets: {' '.join(targets)}")
+    print(f"Wrapper log: {log_path}")
+    print(f"Component logs: {opengauss_repo / 'iceberg-opengauss-build' / 'logs'}")
+
+    if args.dry_run:
+        print("Dry run only; build not executed.")
+        return 0
+
+    log_dir.mkdir(parents=True, exist_ok=True)
+    cmd = [str(build_script), *targets]
+    env = os.environ.copy()
+    env.setdefault("ICEBERG_OG_ROOT", str(root))
+
+    with log_path.open("w", encoding="utf-8", errors="replace") as log:
+        log.write(f"$ {' '.join(shlex.quote(part) for part in cmd)}\n")
+        log.write(f"cwd={opengauss_repo}\n\n")
+        log.flush()
+        proc = subprocess.run(cmd, cwd=str(opengauss_repo), stdout=log, stderr=subprocess.STDOUT, env=env)
+
+    if proc.returncode == 0:
+        print("Build result: success")
+        return 0
+
+    print(f"Build result: failed with exit code {proc.returncode}", file=sys.stderr)
+    print("Failure excerpt:", file=sys.stderr)
+    print(read_error_excerpt(log_path), file=sys.stderr)
+    return proc.returncode
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
