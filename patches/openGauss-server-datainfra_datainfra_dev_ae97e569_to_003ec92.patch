+static bool get_const_limit_count(Query* parse, int64* topK)
+{
+    Const* limitConst = NULL;
+
+    if (parse->limitOffset != NULL || parse->limitCount == NULL || !IsA(parse->limitCount, Const)) {
+        return false;
+    }
+
+    limitConst = (Const*)parse->limitCount;
+    if (limitConst->constisnull) {
+        return false;
+    }
+
+    switch (limitConst->consttype) {
+        case INT8OID:
+            *topK = DatumGetInt64(limitConst->constvalue);
+            break;
+        case INT4OID:
+            *topK = DatumGetInt32(limitConst->constvalue);
+            break;
+        case INT2OID:
+            *topK = DatumGetInt16(limitConst->constvalue);
+            break;
+        default:
+            return false;
+    }
+
+    return *topK >= 0;
+}
+
+static bool is_vector_l2_distance_expr(Node* expr)
+{
+    OpExpr* op = NULL;
+
+    if (expr == NULL) {
+        return false;
+    }
+
+    while (IsA(expr, RelabelType)) {
+        expr = (Node*)((RelabelType*)expr)->arg;
+    }
+
+    if (!IsA(expr, OpExpr)) {
+        return false;
+    }
+
+    op = (OpExpr*)expr;
+    return op->opno == VECTOR_L2_OPERATOR_OID && list_length(op->args) == 2;
+}
+
+static Node* strip_vectorsearch_relabel(Node* expr)
+{
+    while (expr != NULL && IsA(expr, RelabelType)) {
+        expr = (Node*)((RelabelType*)expr)->arg;
+    }
+    return expr;
+}
+
+static int64 vectorsearch_compute_fetch_k(int64 topK)
+{
+    int64 fetchK;
+
+    if (topK <= 0) {
+        return topK;
+    }
+
+    fetchK = topK * VECTORSEARCH_FETCH_MULTIPLIER;
+    if (fetchK < VECTORSEARCH_FETCH_MIN) {
+        fetchK = VECTORSEARCH_FETCH_MIN;
+    }
+    if (fetchK < topK) {
+        fetchK = topK;
+    }
+    if (fetchK > VECTORSEARCH_FETCH_MAX) {
+        fetchK = VECTORSEARCH_FETCH_MAX;
+    }
+    if (fetchK < topK) {
+        fetchK = topK;
+    }
+    return fetchK;
+}
+
+static char* serialize_vectorsearch_query_vector(const float* values, int dim)
+{
+    StringInfoData buf;
+
+    initStringInfo(&buf);
+    for (int i = 0; i < dim; i++) {
+        if (i > 0) {
+            appendStringInfoChar(&buf, ',');
+        }
+        appendStringInfo(&buf, "%.9g", values[i]);
+    }
+    return buf.data;
+}
+
+static bool extract_vectorsearch_l2_hint(Node* expr, AttrNumber* vector_attnum, char** query_vector, int* query_dim)
+{
+    OpExpr* op = NULL;
+    Node* arg1 = NULL;
+    Node* arg2 = NULL;
+    Var* vector_var = NULL;
+    Const* query_const = NULL;
+    PlannerVectorDatum* vector = NULL;
+
+    if (vector_attnum != NULL) {
+        *vector_attnum = InvalidAttrNumber;
+    }
+    if (query_vector != NULL) {
+        *query_vector = NULL;
+    }
+    if (query_dim != NULL) {
+        *query_dim = 0;
+    }
+
+    expr = strip_vectorsearch_relabel(expr);
+    if (expr == NULL || !IsA(expr, OpExpr)) {
+        return false;
+    }
+
+    op = (OpExpr*)expr;
+    if (op->opno != VECTOR_L2_OPERATOR_OID || list_length(op->args) != 2) {
+        return false;
+    }
+
+    arg1 = strip_vectorsearch_relabel((Node*)linitial(op->args));
+    arg2 = strip_vectorsearch_relabel((Node*)lsecond(op->args));
+    if (arg1 != NULL && IsA(arg1, Var) && arg2 != NULL && IsA(arg2, Const)) {
+        vector_var = (Var*)arg1;
+        query_const = (Const*)arg2;
+    } else if (arg2 != NULL && IsA(arg2, Var) && arg1 != NULL && IsA(arg1, Const)) {
+        vector_var = (Var*)arg2;
+        query_const = (Const*)arg1;
+    } else {
+        return false;
+    }
+
+    if (vector_var->varattno <= 0 || query_const->constisnull || query_const->consttype != VECTOROID) {
+        return false;
+    }
+
+    vector = (PlannerVectorDatum*)PG_DETOAST_DATUM(query_const->constvalue);
+    if (vector->dim <= 0) {
+        return false;
+    }
+
+    if (vector_attnum != NULL) {
+        *vector_attnum = vector_var->varattno;
+    }
+    if (query_vector != NULL) {
+        *query_vector = serialize_vectorsearch_query_vector(vector->x, vector->dim);
+    }
+    if (query_dim != NULL) {
+        *query_dim = vector->dim;
+    }
+    return true;
+}
+
+static bool is_foreign_scan(Plan* plan)
+{
+    return plan != NULL && IsA(plan, ForeignScan) && OidIsValid(((ForeignScan*)plan)->scan_relid);
+}
+
+/*
+ * Return true if plan is a LOCAL GATHER (round-robin, consumerDop 1) over a
+ * parallel ForeignScan, and hand that child back through foreign_scan.
+ */
+static bool is_local_gather_foreign_scan(Plan* plan, Plan** foreign_scan)
+{
+    Stream* stream = NULL;
+    Plan* child = NULL;
+
+    if (foreign_scan != NULL) {
+        *foreign_scan = NULL;
+    }
+    if (plan == NULL || !IsA(plan, Stream)) {
+        return false;
+    }
+
+    stream = (Stream*)plan;
+    child = plan->lefttree;
+    if (stream->smpDesc.distriType != LOCAL_ROUNDROBIN || stream->smpDesc.consumerDop != 1 ||
+        stream->smpDesc.producerDop <= 1 || !is_foreign_scan(child)) {
+        return false;
+    }
+
+    /*
+     * Require a genuinely parallel child whose DOP matches producerDop. A serial
+     * child (dop <= 1) under a producerDop > 1 gather is inconsistent: accepting it
+     * lets confirm_parallel_info force the scan multi-threaded and re-scan the same
+     * data, or drive the FDW into a parallel DOP with no task group.
+     */
+    if (child->dop <= 1 || child->dop != stream->smpDesc.producerDop) {
+        return false;
+    }
+    if (foreign_scan != NULL) {
+        *foreign_scan = child;
+    }
+    return true;
+}
+
+/*
+ * Return true if the sort column (sort_col_idx) resolves to the same expression
+ * in both the LOCAL GATHER and its ForeignScan child, i.e. the gather does not
+ * rewrite the ordering column.
+ */
+static bool vectorsearch_local_gather_preserves_sort_col(Plan* gather, Plan* foreign_scan, AttrNumber sort_col_idx)
+{
+    TargetEntry* gather_tle = NULL;
+    TargetEntry* foreign_tle = NULL;
+
+    if (gather == NULL || foreign_scan == NULL) {
+        return false;
+    }
+
+    gather_tle = get_tle_by_resno(gather->targetlist, sort_col_idx);
+    foreign_tle = get_tle_by_resno(foreign_scan->targetlist, sort_col_idx);
+    return gather_tle != NULL && foreign_tle != NULL && equal(gather_tle->expr, foreign_tle->expr);
+}
