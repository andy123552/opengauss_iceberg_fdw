@@ -0,0 +1,93 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+# shellcheck disable=SC1091
+source "$SCRIPT_DIR/env.sh"
+
+require_common_paths
+load_opengauss_env
+
+verify_opengauss() {
+    "$GAUSSHOME/bin/pg_config" --version
+    "$GAUSSHOME/bin/gsql" --version
+    test -x "$GAUSSHOME/bin/gaussdb"
+}
+
+verify_bridge() {
+    require_path "$GAUSSHOME/lib/postgresql/libiceberg_rust_bridge.so"
+    ldd "$GAUSSHOME/lib/postgresql/libiceberg_rust_bridge.so"
+    nm -D "$GAUSSHOME/lib/postgresql/libiceberg_rust_bridge.so" |
+        grep -E 'iceberg_bridge_|iceberg_index_rs_' >/dev/null
+}
+
+verify_fdw() {
+    require_path "$GAUSSHOME/lib/postgresql/iceberg_fdw.so"
+    require_path "$GAUSSHOME/lib/postgresql/proc_srclib/iceberg_fdw.so"
+    require_path "$GAUSSHOME/share/postgresql/extension/iceberg_fdw.control"
+    require_path "$GAUSSHOME/share/postgresql/extension/iceberg_fdw--0.1.0.sql"
+    ldd "$GAUSSHOME/lib/postgresql/iceberg_fdw.so"
+    nm -D "$GAUSSHOME/lib/postgresql/iceberg_fdw.so" |
+        grep 'iceberg_sdk_scan_' >/dev/null
+}
+
+verify_catalog() {
+    require_path "$GAUSSHOME/lib/postgresql/iceberg_catalog.so"
+    require_path "$GAUSSHOME/lib/postgresql/proc_srclib/iceberg_catalog.so"
+    require_path "$GAUSSHOME/share/postgresql/extension/iceberg_catalog.control"
+    require_path "$GAUSSHOME/share/postgresql/extension/iceberg_catalog--1.0.0.sql"
+    ldd "$GAUSSHOME/lib/postgresql/iceberg_catalog.so"
+    nm -D "$GAUSSHOME/lib/postgresql/iceberg_catalog.so" |
+        grep 'iceberg_' >/dev/null
+}
+
+verify_delta() {
+    require_path "$GAUSSHOME/lib/postgresql/iceberg_delta.so"
+    require_path "$GAUSSHOME/lib/postgresql/proc_srclib/iceberg_delta.so"
+    require_path "$GAUSSHOME/share/postgresql/extension/iceberg_delta.control"
+    require_path "$GAUSSHOME/share/postgresql/extension/iceberg_delta--1.0.0.sql"
+    ldd "$GAUSSHOME/lib/postgresql/iceberg_delta.so"
+    nm -D "$GAUSSHOME/lib/postgresql/iceberg_delta.so" |
+        grep 'iceberg_delta' >/dev/null
+}
+
+verify_all() {
+    verify_opengauss
+    verify_bridge
+    verify_fdw
+    verify_catalog
+    verify_delta
+}
+
+if [ "$#" -eq 0 ]; then
+    set -- all
+fi
+
+for target in "$@"; do
+    case "$target" in
+        opengauss)
+            verify_opengauss
+            ;;
+        bridge)
+            verify_bridge
+            ;;
+        fdw)
+            verify_fdw
+            ;;
+        catalog)
+            verify_catalog
+            ;;
+        delta)
+            verify_delta
+            ;;
+        all)
+            verify_all
+            ;;
+        *)
+            echo "unknown verify target: $target" >&2
+            exit 2
+            ;;
+    esac
+done
+
+echo "Build artifacts verified: $*"
