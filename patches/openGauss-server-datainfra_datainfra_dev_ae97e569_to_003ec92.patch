+static bool get_vectorsearch_const_limit_count(Query* parse, int64* topK)
+{
+    Const* limitConst = NULL;
+
+    if (parse == NULL || topK == NULL || parse->limitOffset != NULL || parse->limitCount == NULL ||
+        !IsA(parse->limitCount, Const)) {
+        return false;
+    }
+
+    limitConst = (Const*)parse->limitCount;
+    if (limitConst->constisnull) {
+        return false;
+    }
+
+    switch (limitConst->consttype) {
+        case INT8OID:
+            *topK = DatumGetInt64(limitConst->constvalue);
+            break;
+        case INT4OID:
+            *topK = DatumGetInt32(limitConst->constvalue);
+            break;
+        case INT2OID:
+            *topK = DatumGetInt16(limitConst->constvalue);
+            break;
+        default:
+            return false;
+    }
+
+    return *topK >= 0;
+}
+
+static Node* strip_vectorsearch_relabel(Node* expr)
+{
+    while (expr != NULL && IsA(expr, RelabelType)) {
+        expr = (Node*)((RelabelType*)expr)->arg;
+    }
+    return expr;
+}
+
+static int64 vectorsearch_compute_fetch_k(int64 topK)
+{
+    int64 fetchK;
+
+    if (topK <= 0) {
+        return topK;
+    }
+
+    fetchK = topK * VECTORSEARCH_FETCH_MULTIPLIER;
+    if (fetchK < VECTORSEARCH_FETCH_MIN) {
+        fetchK = VECTORSEARCH_FETCH_MIN;
+    }
+    if (fetchK < topK) {
+        fetchK = topK;
+    }
+    if (fetchK > VECTORSEARCH_FETCH_MAX) {
+        fetchK = VECTORSEARCH_FETCH_MAX;
+    }
+    if (fetchK < topK) {
+        fetchK = topK;
+    }
+    return fetchK;
+}
+
+static char* serialize_vectorsearch_query_vector(const float* values, int dim)
+{
+    StringInfoData buf;
+
+    initStringInfo(&buf);
+    for (int i = 0; i < dim; i++) {
+        if (i > 0) {
+            appendStringInfoChar(&buf, ',');
+        }
+        appendStringInfo(&buf, "%.9g", values[i]);
+    }
+    return buf.data;
+}
+
+static bool extract_vectorsearch_l2_info(Node* expr, Index relid, AttrNumber* vector_attnum, char** query_vector,
+    int* query_dim)
+{
+    OpExpr* op = NULL;
+    Node* arg1 = NULL;
+    Node* arg2 = NULL;
+    Var* vectorVar = NULL;
+    Const* queryConst = NULL;
+    PlannerVectorDatum* vector = NULL;
+
+    expr = strip_vectorsearch_relabel(expr);
+    if (expr == NULL || !IsA(expr, OpExpr)) {
+        return false;
+    }
+
+    op = (OpExpr*)expr;
+    if (op->opno != VECTOR_L2_OPERATOR_OID || list_length(op->args) != 2) {
+        return false;
+    }
+
+    arg1 = strip_vectorsearch_relabel((Node*)linitial(op->args));
+    arg2 = strip_vectorsearch_relabel((Node*)lsecond(op->args));
+    if (arg1 != NULL && IsA(arg1, Var) && arg2 != NULL && IsA(arg2, Const)) {
+        vectorVar = (Var*)arg1;
+        queryConst = (Const*)arg2;
+    } else if (arg2 != NULL && IsA(arg2, Var) && arg1 != NULL && IsA(arg1, Const)) {
+        vectorVar = (Var*)arg2;
+        queryConst = (Const*)arg1;
+    } else {
+        return false;
+    }
+
+    if (vectorVar->varno != relid || vectorVar->varattno <= 0 || queryConst->constisnull ||
+        queryConst->consttype != VECTOROID) {
+        return false;
+    }
+
+    vector = (PlannerVectorDatum*)PG_DETOAST_DATUM(queryConst->constvalue);
+    if (vector->dim <= 0) {
+        return false;
+    }
+
+    if (vector_attnum != NULL) {
+        *vector_attnum = vectorVar->varattno;
+    }
+    if (query_vector != NULL) {
+        *query_vector = serialize_vectorsearch_query_vector(vector->x, vector->dim);
+    }
+    if (query_dim != NULL) {
+        *query_dim = vector->dim;
+    }
+
+    return true;
+}
+
+static bool vectorsearch_topk_info_exists(PlannerInfo* root, Index relid, AttrNumber vector_attnum)
+{
+    ListCell* lc = NULL;
+
+    foreach (lc, root->vectorsearch_topk_infos) {
+        VectorSearchTopKInfo* info = (VectorSearchTopKInfo*)lfirst(lc);
+        if (info != NULL && info->relid == relid && info->vector_attnum == vector_attnum) {
+            return true;
+        }
+    }
+
+    return false;
+}
+
+static void set_vectorsearch_topk_info(PlannerInfo* root, RelOptInfo* rel)
+{
+    Query* parse = root->parse;
+    SortGroupClause* sortClause = NULL;
+    TargetEntry* sortTle = NULL;
+    AttrNumber vectorAttnum = InvalidAttrNumber;
+    char* queryVector = NULL;
+    int queryDim = 0;
+    int64 topK = 0;
+    VectorSearchTopKInfo* info = NULL;
+
+    if (!u_sess->attr.attr_sql.enable_vectorsearch || parse == NULL || rel == NULL || list_length(parse->sortClause) != 1) {
+        return;
+    }
+
+    if (!get_vectorsearch_const_limit_count(parse, &topK)) {
+        return;
+    }
+
+    sortClause = (SortGroupClause*)linitial(parse->sortClause);
+    if (sortClause == NULL || sortClause->sortop != FLOAT8LTOID || sortClause->nulls_first) {
+        return;
+    }
+
+    sortTle = get_sortgroupclause_tle(sortClause, parse->targetList, false);
+    if (sortTle == NULL ||
+        !extract_vectorsearch_l2_info((Node*)sortTle->expr, rel->relid, &vectorAttnum, &queryVector, &queryDim)) {
+        return;
+    }
+
+    if (vectorsearch_topk_info_exists(root, rel->relid, vectorAttnum)) {
+        return;
+    }
+
+    info = (VectorSearchTopKInfo*)palloc0(sizeof(VectorSearchTopKInfo));
+    info->relid = rel->relid;
+    info->vector_attnum = vectorAttnum;
+    info->topK = topK;
+    info->fetchK = vectorsearch_compute_fetch_k(topK);
+    info->query_vector = queryVector;
+    info->query_dim = queryDim;
+    info->metric = (char*)"l2";
+    root->vectorsearch_topk_infos = lappend(root->vectorsearch_topk_infos, info);
+}
