+#!/usr/bin/env bash
+set -euo pipefail
+
+# Shared paths for the local Iceberg + openGauss build.
+# By default this directory lives under openGauss-server-datainfra, so the
+# multi-repository root is the parent directory of the openGauss checkout.
+# Override ICEBERG_OG_ROOT before sourcing if the checkout layout is different.
+ICEBERG_OG_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+ICEBERG_OG_DEFAULT_ROOT="$(cd "$ICEBERG_OG_SCRIPT_DIR/../.." && pwd)"
+
+# Machine-local overrides live outside versioned scripts. Each variable can
+# also be set in the shell before invoking a build command.
+export ICEBERG_OG_LOCAL_ENV="${ICEBERG_OG_LOCAL_ENV:-$ICEBERG_OG_SCRIPT_DIR/local.env}"
+if [ -f "$ICEBERG_OG_LOCAL_ENV" ]; then
+    # shellcheck disable=SC1090
+    source "$ICEBERG_OG_LOCAL_ENV"
+fi
+
+mark_user_override() {
+    local name="$1"
+    local marker="ICEBERG_OG_USER_${name}"
+    if [ "${!name+x}" ]; then
+        export "$marker=1"
+    fi
+}
+
+for iceberg_og_var in \
+    GAUSSHOME \
+    OPENGAUSS_BUILD_MODE \
+    OPENGAUSS_GCC_VERSION \
+    OPENGAUSS_CFLAGS \
+    OPENGAUSS_EXTRA_CONFIG_OPT \
+    OPENGAUSS_CC \
+    OPENGAUSS_CXX \
+    BUILD_JOBS \
+    INSTALL_JOBS
+do
+    mark_user_override "$iceberg_og_var"
+done
+unset iceberg_og_var
+
+export ICEBERG_OG_ROOT="${ICEBERG_OG_ROOT:-$ICEBERG_OG_DEFAULT_ROOT}"
+export OPENGAUSS_REPO="${OPENGAUSS_REPO:-$ICEBERG_OG_ROOT/openGauss-server-datainfra}"
+export ICEBERG_INDEX_REPO="${ICEBERG_INDEX_REPO:-$ICEBERG_OG_ROOT/iceberg-index}"
+export ICEBERG_BRIDGE_REPO="${ICEBERG_BRIDGE_REPO:-$ICEBERG_OG_ROOT/iceberg-rust-bridge}"
+export ICEBERG_FDW_REPO="${ICEBERG_FDW_REPO:-$ICEBERG_OG_ROOT/iceberg_fdw}"
+export ICEBERG_CATALOG_REPO="${ICEBERG_CATALOG_REPO:-$ICEBERG_OG_ROOT/openGauss-Catalog}"
+export ICEBERG_DELTA_REPO="${ICEBERG_DELTA_REPO:-$ICEBERG_OG_ROOT/iceberg_delta}"
+export ICEBERG_RUST_REPO="${ICEBERG_RUST_REPO:-$ICEBERG_OG_ROOT/iceberg-rust-datainfra}"
+export BINARYLIBS_DIR="${BINARYLIBS_DIR:-$ICEBERG_OG_ROOT/binarylibs}"
+export OPENGAUSS_ENV="${OPENGAUSS_ENV:-$ICEBERG_OG_ROOT/opengauss.env}"
+export GAUSSHOME="${GAUSSHOME:-$ICEBERG_OG_ROOT/mppdb_temp_install}"
+export OG_PYTHON_SHIM="${OG_PYTHON_SHIM:-${TMPDIR:-/tmp}/og-python-bin}"
+export ICEBERG_DELTA_BUILD_DIR="${ICEBERG_DELTA_BUILD_DIR:-$ICEBERG_DELTA_REPO/tmp_build_gcc10}"
+export ARROW_HOME="${ARROW_HOME:-$ICEBERG_OG_ROOT/arrow_install}"
+export CMAKE_BIN="${CMAKE_BIN:-cmake}"
+export OPENGAUSS_GCC_HOME="${OPENGAUSS_GCC_HOME:-$BINARYLIBS_DIR/buildtools/gcc10.3}"
+export OPENGAUSS_CC="${OPENGAUSS_CC:-$OPENGAUSS_GCC_HOME/gcc/bin/gcc}"
+export OPENGAUSS_CXX="${OPENGAUSS_CXX:-$OPENGAUSS_GCC_HOME/gcc/bin/g++}"
+export CC="$OPENGAUSS_CC"
+export CXX="$OPENGAUSS_CXX"
+export OPENGAUSS_PYTHON_HOME="${OPENGAUSS_PYTHON_HOME:-$BINARYLIBS_DIR/kernel/platform/python3.7}"
+export OPENGAUSS_OPENSSL_HOME="${OPENGAUSS_OPENSSL_HOME:-$BINARYLIBS_DIR/kernel/dependency/openssl/comm}"
+export OPENGAUSS_THIRD_INCLUDE_PATH="${OPENGAUSS_THIRD_INCLUDE_PATH:-$OPENGAUSS_OPENSSL_HOME/include:$BINARYLIBS_DIR/kernel/dependency/libcgroup/comm/include:$BINARYLIBS_DIR/kernel/dependency/boost/comm/include:$BINARYLIBS_DIR/kernel/dependency/cjson/comm/include:$BINARYLIBS_DIR/kernel/dependency/zlib1.2.11/comm/include:$BINARYLIBS_DIR/kernel/dependency/zstd/include:$BINARYLIBS_DIR/kernel/dependency/libcurl/comm/include:$BINARYLIBS_DIR/kernel/dependency/aws-sdk-cpp/comm/include:$BINARYLIBS_DIR/kernel/component/dcf/include:$OPENGAUSS_PYTHON_HOME/include/python3.7m:$BINARYLIBS_DIR/kernel/dependency/masstree/comm/include}"
+export OPENGAUSS_THIRD_LIB_PATH="${OPENGAUSS_THIRD_LIB_PATH:-$OPENGAUSS_GCC_HOME/gcc/lib64:$OPENGAUSS_GCC_HOME/isl/lib:$OPENGAUSS_GCC_HOME/mpc/lib:$OPENGAUSS_GCC_HOME/mpfr/lib:$OPENGAUSS_GCC_HOME/gmp/lib:$OPENGAUSS_PYTHON_HOME/lib:$OPENGAUSS_PYTHON_HOME/lib64:$OPENGAUSS_OPENSSL_HOME/lib}"
+export ICEBERG_OG_LOG_DIR="${ICEBERG_OG_LOG_DIR:-$ICEBERG_OG_SCRIPT_DIR/logs}"
+export ICEBERG_OG_LOG_FAILURE_LINES="${ICEBERG_OG_LOG_FAILURE_LINES:-160}"
+
+require_path() {
+    local path="$1"
+    if [ ! -e "$path" ]; then
+        echo "missing required path: $path" >&2
+        exit 1
+    fi
+}
+
+require_tool() {
+    local tool="$1"
+    if ! command -v "$tool" >/dev/null 2>&1; then
+        echo "missing required tool in PATH: $tool" >&2
+        exit 127
+    fi
+}
+
+require_executable() {
+    local executable="$1"
+    if [[ "$executable" == */* ]]; then
+        if [ -x "$executable" ]; then
+            return
+        fi
+    elif command -v "$executable" >/dev/null 2>&1; then
+        return
+    fi
+
+    echo "missing required executable: $executable" >&2
+    if [ "$executable" = "cmake" ]; then
+        echo "set CMAKE_BIN=/path/to/cmake or add cmake to PATH" >&2
+    fi
+    exit 127
+}
+
+iceberg_og_safe_name() {
+    printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '-'
+}
+
+iceberg_og_log_excerpt() {
+    local log_file="$1"
+    local max_lines="${2:-$ICEBERG_OG_LOG_FAILURE_LINES}"
+
+    if [ ! -f "$log_file" ]; then
+        echo "log file not found: $log_file" >&2
+        return
+    fi
+
+    local matches
+    matches="$(grep -nEi -A 5 'error:|fatal:|CMake Error|undefined reference|No such file|cannot find|recipe for target|collect2: error|Traceback|panic|failed|make(\[[0-9]+\])?: \*\*\*|Segmentation fault' "$log_file" | head -n "$max_lines" || true)"
+    if [ -n "$matches" ]; then
+        echo "$matches" >&2
+    else
+        tail -n 80 "$log_file" >&2
+    fi
+}
+
+run_logged_step() {
+    local label="$1"
+    shift
+
+    mkdir -p "$ICEBERG_OG_LOG_DIR"
+    local log_file
+    log_file="$ICEBERG_OG_LOG_DIR/$(date +%Y%m%d-%H%M%S)-$(iceberg_og_safe_name "$label").log"
+
+    echo "==> $label"
+    echo "[LOG] $log_file"
+
+    local rc
+    (
+        export ICEBERG_OG_LOGGING_ACTIVE=1
+        "$@"
+    ) >"$log_file" 2>&1
+    rc=$?
+
+    if [ "$rc" -eq 0 ]; then
+        echo "[OK] $label"
+        return 0
+    fi
+
+    echo "[FAIL] $label exited with code $rc" >&2
+    echo "[FAIL] log: $log_file" >&2
+    echo "[FAIL] excerpt:" >&2
+    iceberg_og_log_excerpt "$log_file"
+    return "$rc"
+}
+
+require_common_paths() {
+    require_path "$OPENGAUSS_REPO"
+    require_path "$ICEBERG_INDEX_REPO"
+    require_path "$ICEBERG_BRIDGE_REPO"
+    require_path "$ICEBERG_FDW_REPO"
+    require_path "$ICEBERG_CATALOG_REPO"
+    require_path "$ICEBERG_DELTA_REPO"
+    require_path "$BINARYLIBS_DIR"
+    require_path "$OPENGAUSS_ENV"
+}
+
+load_rust_env() {
+    if [ -f "$HOME/.cargo/env" ]; then
+        # shellcheck disable=SC1091
+        source "$HOME/.cargo/env"
+    fi
+    rustc --version
+    cargo --version
+}
+
+enter_clean_rust_env() {
+    load_rust_env
+    unset PG_CONFIG GSQL_HOST GSQL_PORT
+    # Do not inherit openGauss libstdc++.so.6 into cargo builds, but keep
+    # the GCC 10.3 toolchain runtime libraries (libisl, libmpc, libmpfr,
+    # libgmp) so that cargo-invoked C compilers can still run.
+    export LD_LIBRARY_PATH="$OPENGAUSS_GCC_HOME/gcc/lib64:$OPENGAUSS_GCC_HOME/isl/lib:$OPENGAUSS_GCC_HOME/mpc/lib:$OPENGAUSS_GCC_HOME/mpfr/lib:$OPENGAUSS_GCC_HOME/gmp/lib"
+}
+
+load_opengauss_env() {
+    local iceberg_og_var
+    for iceberg_og_var in \
+        GAUSSHOME \
+        OPENGAUSS_BUILD_MODE \
+        OPENGAUSS_GCC_VERSION \
+        OPENGAUSS_CFLAGS \
+        OPENGAUSS_EXTRA_CONFIG_OPT \
+        OPENGAUSS_CC \
+        OPENGAUSS_CXX \
+        BUILD_JOBS \
+        INSTALL_JOBS
+    do
+        local "ICEBERG_OG_SAVED_${iceberg_og_var}=${!iceberg_og_var-}"
+    done
+
+    # shellcheck disable=SC1090
+    source "$OPENGAUSS_ENV"
+
+    for iceberg_og_var in \
+        GAUSSHOME \
+        OPENGAUSS_BUILD_MODE \
+        OPENGAUSS_GCC_VERSION \
+        OPENGAUSS_CFLAGS \
+        OPENGAUSS_EXTRA_CONFIG_OPT \
+        OPENGAUSS_CC \
+        OPENGAUSS_CXX \
+        BUILD_JOBS \
+        INSTALL_JOBS
+    do
+        local marker="ICEBERG_OG_USER_${iceberg_og_var}"
+        local saved="ICEBERG_OG_SAVED_${iceberg_og_var}"
+        if [ "${!marker:-}" ]; then
+            export "$iceberg_og_var=${!saved}"
+        fi
+    done
+
+    export GAUSSHOME="${GAUSSHOME:-$ICEBERG_OG_ROOT/mppdb_temp_install}"
+    export CC="$OPENGAUSS_CC"
+    export CXX="$OPENGAUSS_CXX"
+    export PATH="$OG_PYTHON_SHIM:$OPENGAUSS_GCC_HOME/gcc/bin:$GAUSSHOME/bin:$PATH"
+    export LD_LIBRARY_PATH="$GAUSSHOME/lib:$GAUSSHOME/lib/postgresql:$OPENGAUSS_THIRD_LIB_PATH:${LD_LIBRARY_PATH:-}"
+}
+
+ensure_python_shim() {
+    mkdir -p "$OG_PYTHON_SHIM"
+    ln -sfn "$OPENGAUSS_PYTHON_HOME/bin/python3.7" "$OG_PYTHON_SHIM/python"
+    ln -sfn "$OPENGAUSS_PYTHON_HOME/bin/python3.7" "$OG_PYTHON_SHIM/python3"
+}
+
+make_install_tree_writable() {
+    # Reinstalling openGauss can fail when copied jre/python files are 0444.
+    if [ -d "$GAUSSHOME/jre" ]; then
+        chmod -R u+w "$GAUSSHOME/jre"
+    fi
+    if [ -d "$GAUSSHOME/python" ]; then
+        chmod -R u+w "$GAUSSHOME/python"
+    fi
+}
+
+ensure_pg_extension_dirs() {
+    mkdir -p "$GAUSSHOME/lib/postgresql" \
+        "$GAUSSHOME/lib/postgresql/proc_srclib" \
+        "$GAUSSHOME/share/postgresql/extension"
+}
+
+install_extension_triplet() {
+    local name="$1"
+    local so_path="$2"
+    local control_path="$3"
+    local sql_path="$4"
+
+    ensure_pg_extension_dirs
+    require_path "$so_path"
+    require_path "$control_path"
+    require_path "$sql_path"
+
+    install -m 755 "$so_path" "$GAUSSHOME/lib/postgresql/$name.so"
+    install -m 755 "$so_path" "$GAUSSHOME/lib/postgresql/proc_srclib/$name.so"
+    install -m 644 "$control_path" "$GAUSSHOME/share/postgresql/extension/$name.control"
+    install -m 644 "$sql_path" "$GAUSSHOME/share/postgresql/extension/$(basename "$sql_path")"
+    echo "installed extension: $name"
+}
+
+bridge_index_patch_args=(
+    --config "patch.\"https://github.com/DataInfraLab/iceberg-index.git\".iceberg-index-abi.path=\"$ICEBERG_INDEX_REPO/crates/iceberg-index-abi\""
+    --config "patch.\"https://github.com/DataInfraLab/iceberg-index.git\".iceberg-index-core.path=\"$ICEBERG_INDEX_REPO/crates/iceberg-index-core\""
+    --config "patch.\"https://github.com/DataInfraLab/iceberg-index.git\".iceberg-index-iceberg.path=\"$ICEBERG_INDEX_REPO/crates/iceberg-index-iceberg\""
+    --config "patch.\"https://github.com/DataInfraLab/iceberg-index.git\".iceberg-index-plugins.path=\"$ICEBERG_INDEX_REPO/crates/iceberg-index-plugins\""
+    --config "patch.\"https://github.com/DataInfraLab/iceberg-index.git\".iceberg-index-runtime.path=\"$ICEBERG_INDEX_REPO/crates/iceberg-index-runtime\""
+    --config "patch.\"https://github.com/DataInfraLab/iceberg-index.git\".iceberg-index-service.path=\"$ICEBERG_INDEX_REPO/crates/iceberg-index-service\""
+)
