+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+# shellcheck disable=SC1091
+source "$SCRIPT_DIR/env.sh"
+
+usage() {
+    cat <<'USAGE'
+Usage:
+  build-component.sh <component> [component ...]
+
+Components:
+  opengauss       Build and install openGauss-server-datainfra.
+  index           Check iceberg-index only.
+  bridge          Build iceberg-rust-bridge and install libiceberg_rust_bridge.so.
+  bridge-build    Build iceberg-rust-bridge only.
+  bridge-install  Install an existing bridge .so into $GAUSSHOME.
+  fdw             Build and install iceberg_fdw.
+  fdw-build       Build iceberg_fdw only.
+  fdw-install     Install an existing iceberg_fdw.so/control/sql into $GAUSSHOME.
+  catalog         Build and install openGauss-Catalog.
+  catalog-build   Build openGauss-Catalog only.
+  catalog-install Install existing iceberg_catalog artifacts into $GAUSSHOME.
+  delta           Build and install iceberg_delta.
+  delta-build     Build iceberg_delta only.
+  delta-install   Install existing iceberg_delta artifacts into $GAUSSHOME.
+  rust            Run index + bridge.
+  assemble        Install existing bridge, FDW, catalog, and delta artifacts.
+  verify          Verify all installed build artifacts.
+  verify-opengauss Verify openGauss installation only.
+  verify-bridge  Verify bridge installation only.
+  verify-fdw     Verify iceberg_fdw installation only.
+  verify-catalog Verify iceberg_catalog installation only.
+  verify-delta   Verify iceberg_delta installation only.
+  verify-all     Verify all installed build artifacts.
+  all             Run the full build-all.sh flow.
+
+Examples:
+  ./iceberg-opengauss-build/build-component.sh bridge verify
+  ./iceberg-opengauss-build/build-component.sh fdw verify
+  ./iceberg-opengauss-build/build-component.sh assemble verify
+USAGE
+}
+
+build_opengauss() {
+    "$SCRIPT_DIR/01-build-opengauss.sh"
+}
+
+check_index() {
+    require_common_paths
+    enter_clean_rust_env
+    cd "$ICEBERG_INDEX_REPO"
+    cargo check --workspace
+}
+
+build_bridge() {
+    require_common_paths
+    enter_clean_rust_env
+    cd "$ICEBERG_BRIDGE_REPO"
+    cargo build --release "${bridge_index_patch_args[@]}"
+    require_path "$ICEBERG_BRIDGE_REPO/target/release/libiceberg_rust_bridge.so"
+}
+
+install_bridge() {
+    require_common_paths
+    load_opengauss_env
+    require_path "$ICEBERG_BRIDGE_REPO/target/release/libiceberg_rust_bridge.so"
+    mkdir -p "$GAUSSHOME/lib/postgresql"
+    cp "$ICEBERG_BRIDGE_REPO/target/release/libiceberg_rust_bridge.so" \
+        "$GAUSSHOME/lib/postgresql/libiceberg_rust_bridge.so"
+    echo "installed bridge: $GAUSSHOME/lib/postgresql/libiceberg_rust_bridge.so"
+}
+
+prepare_catalog_deps() {
+    require_common_paths
+    require_path "$ICEBERG_BRIDGE_REPO/target/release/libiceberg_rust_bridge.so"
+    require_path "$ICEBERG_BRIDGE_REPO/include/iceberg_bridge.h"
+    mkdir -p "$ICEBERG_CATALOG_REPO/deps"
+    cp "$ICEBERG_BRIDGE_REPO/target/release/libiceberg_rust_bridge.so" \
+        "$ICEBERG_CATALOG_REPO/deps/libiceberg_rust_bridge.so"
+    cp "$ICEBERG_BRIDGE_REPO/include/iceberg_bridge.h" \
+        "$ICEBERG_CATALOG_REPO/deps/iceberg_bridge.h"
+}
+
+build_fdw() {
+    require_common_paths
+    load_opengauss_env
+    cd "$ICEBERG_FDW_REPO"
+    make PG_CONFIG="$GAUSSHOME/bin/pg_config" \
+        OPENGAUSS_SRC_INCLUDE="$OPENGAUSS_REPO/src/include"
+}
+
+install_fdw() {
+    require_common_paths
+    load_opengauss_env
+    install_extension_triplet \
+        "iceberg_fdw" \
+        "$ICEBERG_FDW_REPO/iceberg_fdw.so" \
+        "$ICEBERG_FDW_REPO/iceberg_fdw.control" \
+        "$ICEBERG_FDW_REPO/iceberg_fdw--0.1.0.sql"
+}
+
+build_and_install_fdw() {
+    build_fdw
+    install_fdw
+}
+
+build_catalog() {
+    require_common_paths
+    load_opengauss_env
+    prepare_catalog_deps
+    cd "$ICEBERG_CATALOG_REPO"
+    make PG_CONFIG="$GAUSSHOME/bin/pg_config" GAUSS_SRC="$OPENGAUSS_REPO"
+}
+
+install_catalog() {
+    require_common_paths
+    load_opengauss_env
+    install_extension_triplet \
+        "iceberg_catalog" \
+        "$ICEBERG_CATALOG_REPO/iceberg_catalog.so" \
+        "$ICEBERG_CATALOG_REPO/iceberg_catalog.control" \
+        "$ICEBERG_CATALOG_REPO/iceberg_catalog--1.0.0.sql"
+}
+
+build_and_install_catalog() {
+    build_catalog
+    install_catalog
+}
+
+build_delta() {
+    require_common_paths
+    load_opengauss_env
+    require_executable "$CMAKE_BIN"
+    require_executable "$OPENGAUSS_CC"
+    require_executable "$OPENGAUSS_CXX"
+    mkdir -p "$ICEBERG_DELTA_BUILD_DIR"
+    cd "$ICEBERG_DELTA_BUILD_DIR"
+    export CC="$OPENGAUSS_CC"
+    export CXX="$OPENGAUSS_CXX"
+    export CPATH="$OPENGAUSS_THIRD_INCLUDE_PATH:${CPATH:-}"
+    "$CMAKE_BIN" "$ICEBERG_DELTA_REPO" -DGAUSS_SRC="$OPENGAUSS_REPO"
+    "$CMAKE_BIN" --build . --parallel "${BUILD_JOBS:-8}"
+}
+
+install_delta() {
+    require_common_paths
+    load_opengauss_env
+    install_extension_triplet \
+        "iceberg_delta" \
+        "$ICEBERG_DELTA_BUILD_DIR/iceberg_delta.so" \
+        "$ICEBERG_DELTA_REPO/iceberg_delta.control" \
+        "$ICEBERG_DELTA_REPO/iceberg_delta--1.0.0.sql"
+}
+
+build_and_install_delta() {
+    build_delta
+    install_delta
+}
+
+verify_build() {
+    "$SCRIPT_DIR/04-verify-build.sh" "$@"
+}
+
+run_component() {
+    case "$1" in
+        opengauss)
+            build_opengauss
+            ;;
+        index)
+            check_index
+            ;;
+        bridge)
+            build_bridge
+            install_bridge
+            ;;
+        bridge-build)
+            build_bridge
+            ;;
+        bridge-install)
+            install_bridge
+            ;;
+        fdw)
+            build_and_install_fdw
+            ;;
+        fdw-build)
+            build_fdw
+            ;;
+        fdw-install)
+            install_fdw
+            ;;
+        catalog)
+            build_and_install_catalog
+            ;;
+        catalog-build)
+            build_catalog
+            ;;
+        catalog-install)
+            install_catalog
+            ;;
+        delta)
+            build_and_install_delta
+            ;;
+        delta-build)
+            build_delta
+            ;;
+        delta-install)
+            install_delta
+            ;;
+        rust)
+            check_index
+            build_bridge
+            install_bridge
+            ;;
+        assemble)
+            install_bridge
+            install_fdw
+            install_catalog
+            install_delta
+            ;;
+        verify)
+            verify_build all
+            ;;
+        verify-opengauss)
+            verify_build opengauss
+            ;;
+        verify-bridge)
+            verify_build bridge
+            ;;
+        verify-fdw)
+            verify_build fdw
+            ;;
+        verify-catalog)
+            verify_build catalog
+            ;;
+        verify-delta)
+            verify_build delta
+            ;;
+        verify-all)
+            verify_build all
+            ;;
+        all)
+            "$SCRIPT_DIR/build-all.sh"
+            ;;
+        -h|--help|help)
+            usage
+            ;;
+        *)
+            echo "unknown component: $1" >&2
+            usage >&2
+            exit 2
+            ;;
+    esac
+}
+
+if [ "$#" -eq 0 ]; then
+    usage >&2
+    exit 2
+fi
+
+for component in "$@"; do
+    if [ "${ICEBERG_OG_LOGGING_ACTIVE:-0}" = "1" ]; then
+        echo "==> $component"
+        run_component "$component"
+    else
+        run_logged_step "component-$component" run_component "$component"
+    fi
+done
