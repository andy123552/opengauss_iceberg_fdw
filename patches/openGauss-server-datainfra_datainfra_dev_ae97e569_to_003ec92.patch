+static Plan* try_make_vectorsearch_from_sort(Query* parse, PlannerInfo* root, Sort* sortPlan, double limitTuples)
+{
+    VectorSearch* node = NULL;
+    Plan* plan = NULL;
+    Plan* lefttree = NULL;
+    Plan* foreign_scan = NULL;
+    TargetEntry* sortTle = NULL;
+    int64 topK = 0;
+    int64 fetchK = 0;
+    char* queryVector = NULL;
+    int queryDim = 0;
+    bool need_local_gather = false;
+
+    if (!u_sess->attr.attr_sql.enable_vectorsearch) {
+        return (Plan*)sortPlan;
+    }
+
+    if (sortPlan == NULL || sortPlan->numCols != 1 || sortPlan->sortColIdx == NULL ||
+        sortPlan->sortOperators == NULL || sortPlan->collations == NULL || sortPlan->nullsFirst == NULL) {
+        return (Plan*)sortPlan;
+    }
+
+    if (sortPlan->sortOperators[0] != FLOAT8LTOID || sortPlan->nullsFirst[0]) {
+        return (Plan*)sortPlan;
+    }
+
+    if (!get_const_limit_count(parse, &topK)) {
+        return (Plan*)sortPlan;
+    }
+
+    lefttree = sortPlan->plan.lefttree;
+    if (!is_foreign_scan(lefttree)) {
+        if (!is_local_gather_foreign_scan(lefttree, &foreign_scan) ||
+            !vectorsearch_local_gather_preserves_sort_col(lefttree, foreign_scan, sortPlan->sortColIdx[0])) {
+            return (Plan*)sortPlan;
+        }
+    } else if (lefttree->dop > 1) {
+        /*
+         * make_sort_from_pathkeys skips the LOCAL GATHER when the LIMIT count is
+         * no larger than the per-worker row estimate, leaving a bare parallel
+         * ForeignScan here. Building VectorSearch at dop > 1 would make every
+         * worker emit a partition-local top-K, and the non-merging gather that
+         * parallel_limit_sort adds later would surface an interleaved, non-global
+         * result. Defer inserting the gather until the sort column is confirmed to
+         * be a supported vector distance, so a non-vector parallel sort keeps its
+         * original shape. create_local_gather copies the child targetlist, so the
+         * validation below resolves the same sort expression on the bare scan.
+         */
+        need_local_gather = true;
+    } else {
+        foreign_scan = lefttree;
+    }
+
+    sortTle = get_tle_by_resno(lefttree->targetlist, sortPlan->sortColIdx[0]);
+    if (sortTle == NULL || !is_vector_l2_distance_expr((Node*)sortTle->expr) ||
+        !extract_vectorsearch_l2_hint((Node*)sortTle->expr, NULL, &queryVector, &queryDim)) {
+        return (Plan*)sortPlan;
+    }
+
