+static TupleTableSlot* ExecVectorSearch(PlanState* state);
+
+static inline bool VectorSearchCandidateGreater(const VectorSearchCandidate* left, const VectorSearchCandidate* right)
+{
+    if (left->distance > right->distance) {
+        return true;
+    }
+    if (left->distance < right->distance) {
+        return false;
+    }
+    return left->seq > right->seq;
+}
+
+static void VectorSearchSwap(VectorSearchCandidate* left, VectorSearchCandidate* right)
+{
+    VectorSearchCandidate tmp = *left;
+    *left = *right;
+    *right = tmp;
+}
+
+static void VectorSearchHeapSiftUp(VectorSearchState* node, int64 index)
+{
+    while (index > 0) {
+        int64 parent = (index - 1) / 2;
+        if (!VectorSearchCandidateGreater(&node->candidates[index], &node->candidates[parent])) {
+            break;
+        }
+        VectorSearchSwap(&node->candidates[index], &node->candidates[parent]);
+        index = parent;
+    }
+}
+
+static void VectorSearchHeapSiftDown(VectorSearchState* node, int64 index)
+{
+    for (;;) {
+        int64 left = index * 2 + 1;
+        int64 right = left + 1;
+        int64 largest = index;
+
+        if (left < node->heapSize &&
+            VectorSearchCandidateGreater(&node->candidates[left], &node->candidates[largest])) {
+            largest = left;
+        }
+
+        if (right < node->heapSize &&
+            VectorSearchCandidateGreater(&node->candidates[right], &node->candidates[largest])) {
+            largest = right;
+        }
+
+        if (largest == index) {
+            break;
+        }
+
+        VectorSearchSwap(&node->candidates[index], &node->candidates[largest]);
+        index = largest;
+    }
+}
+
+static int VectorSearchResultCompare(const void* left, const void* right)
+{
+    const VectorSearchCandidate* l = (const VectorSearchCandidate*)left;
+    const VectorSearchCandidate* r = (const VectorSearchCandidate*)right;
+
+    if (l->distance < r->distance) {
+        return -1;
+    }
+    if (l->distance > r->distance) {
+        return 1;
+    }
+    if (l->seq < r->seq) {
+        return -1;
+    }
+    if (l->seq > r->seq) {
+        return 1;
+    }
+    return 0;
+}
+
+static void VectorSearchResetResults(VectorSearchState* node)
+{
+    if (node->tupleContext != NULL) {
+        MemoryContextReset(node->tupleContext);
+    }
+
+    node->search_Done = false;
+    node->heapSize = 0;
+    node->resultCount = 0;
+    node->resultIndex = 0;
+    node->inputRows = 0;
+    node->distanceComputations = 0;
+    node->seq = 0;
+    node->candidates = NULL;
+}
+
+static void VectorSearchSaveCandidate(VectorSearchState* node, TupleTableSlot* slot, double distance)
+{
+    MemoryContext oldContext = MemoryContextSwitchTo(node->tupleContext);
+    MinimalTuple tuple = ExecCopySlotMinimalTuple(slot);
+    MemoryContextSwitchTo(oldContext);
+
+    VectorSearchCandidate candidate;
+    candidate.tuple = tuple;
+    candidate.distance = distance;
+    candidate.seq = node->seq++;
+
+    if (node->heapSize < node->heapCapacity) {
+        node->candidates[node->heapSize] = candidate;
+        node->heapSize++;
+        VectorSearchHeapSiftUp(node, node->heapSize - 1);
+        return;
+    }
+
+    if (node->heapSize == 0 || !VectorSearchCandidateGreater(&node->candidates[0], &candidate)) {
+        heap_free_minimal_tuple(tuple);
+        return;
+    }
+
+    heap_free_minimal_tuple(node->candidates[0].tuple);
+    node->candidates[0] = candidate;
+    VectorSearchHeapSiftDown(node, 0);
+}
+
+static void VectorSearchBuildTopK(VectorSearchState* node)
+{
+    VectorSearch* plan = (VectorSearch*)node->ss.ps.plan;
+    PlanState* outerNode = outerPlanState(node);
+    AttrNumber distanceCol = plan->sortColIdx[0];
+    EState* estate = node->ss.ps.state;
+    ScanDirection oldDirection = estate->es_direction;
+
+    estate->es_direction = ForwardScanDirection;
+
+    MemoryContext oldContext = MemoryContextSwitchTo(node->tupleContext);
+    node->candidates = (VectorSearchCandidate*)palloc0(sizeof(VectorSearchCandidate) * node->heapCapacity);
+    MemoryContextSwitchTo(oldContext);
+
+    for (;;) {
+        bool isNull = false;
+        Datum distanceDatum;
+        double distance;
+        TupleTableSlot* slot = ExecProcNode(outerNode);
+
+        if (TupIsNull(slot)) {
+            break;
+        }
+
+        node->inputRows++;
+        distanceDatum = heap_slot_getattr(slot, distanceCol, &isNull);
+        if (isNull) {
+            continue;
+        }
+
+        distance = DatumGetFloat8(distanceDatum);
+        node->distanceComputations++;
+        VectorSearchSaveCandidate(node, slot, distance);
+    }
+
+    estate->es_direction = oldDirection;
+
+    node->resultCount = node->heapSize;
+    node->resultIndex = 0;
+
+    if (node->resultCount > 1) {
+        qsort(node->candidates, node->resultCount, sizeof(VectorSearchCandidate), VectorSearchResultCompare);
+    }
+
+    ExecEarlyFree(outerPlanState(node));
+    node->search_Done = true;
+}
+
+static TupleTableSlot* ExecVectorSearch(PlanState* state)
+{
+    VectorSearchState* node = castNode(VectorSearchState, state);
+    TupleTableSlot* resultSlot = node->ss.ps.ps_ResultTupleSlot;
+
+    CHECK_FOR_INTERRUPTS();
+
+    if (node->topK <= 0) {
+        return ExecClearTuple(resultSlot);
+    }
+
+    if (!node->search_Done) {
+        VectorSearchBuildTopK(node);
+    }
+
+    if (node->resultIndex >= node->resultCount) {
+        return ExecClearTuple(resultSlot);
+    }
+
+    return ExecStoreMinimalTuple(node->candidates[node->resultIndex++].tuple, resultSlot, false);
+}
+
+VectorSearchState* ExecInitVectorSearch(VectorSearch* node, EState* estate, int eflags)
+{
+    VectorSearchState* state = makeNode(VectorSearchState);
+
+    state->ss.ps.plan = (Plan*)node;
+    state->ss.ps.state = estate;
+    state->ss.ps.ExecProcNode = ExecVectorSearch;
+    state->topK = node->topK;
+    state->fetchK = node->fetchK;
+    state->heapCapacity = node->topK;
+    state->tupleContext = AllocSetContextCreate(CurrentMemoryContext,
+        "VectorSearch TopK context",
+        ALLOCSET_DEFAULT_SIZES);
+
+    ExecInitResultTupleSlot(estate, &state->ss.ps);
+    ExecInitScanTupleSlot(estate, &state->ss);
+
+    eflags &= ~(EXEC_FLAG_REWIND | EXEC_FLAG_BACKWARD | EXEC_FLAG_MARK);
+    outerPlanState(state) = ExecInitNode(outerPlan(node), estate, eflags);
+
+    ExecAssignScanTypeFromOuterPlan(&state->ss);
+    ExecAssignResultTypeFromTL(&state->ss.ps, state->ss.ss_ScanTupleSlot->tts_tupleDescriptor->td_tam_ops);
+    state->ss.ps.ps_ProjInfo = NULL;
+
+    VectorSearchResetResults(state);
+
+    return state;
+}
+
+void ExecEndVectorSearch(VectorSearchState* node)
+{
+    (void)ExecClearTuple(node->ss.ss_ScanTupleSlot);
+    (void)ExecClearTuple(node->ss.ps.ps_ResultTupleSlot);
+
+    if (node->tupleContext != NULL) {
+        MemoryContextDelete(node->tupleContext);
+        node->tupleContext = NULL;
+    }
+
+    ExecEndNode(outerPlanState(node));
+}
+
+void ExecReScanVectorSearch(VectorSearchState* node)
+{
+    /*
+     * The top-K result is fully materialized in node->candidates. Without a
+     * parameter change the child reproduces the same input, so rewind the result
+     * cursor and replay the cached candidates. This skips rescanning the child,
+     * and in particular avoids rescanning a LOCAL GATHER (Stream) child, which
+     * the executor forbids.
+     */
+    if (node->ss.ps.lefttree->chgParam == NULL) {
+        node->resultIndex = 0;
+        return;
+    }
+
+    /*
+     * A parameter change requires rebuilding from the child. A serial ForeignScan
+     * child is rescanned safely through chgParam propagation, but a parallel LOCAL
+     * GATHER (Stream) child cannot be rescanned. Such a shape should not reach a
+     * parameterized rescan; fail loudly instead of returning silently wrong rows.
+     */
+    if (IsA(node->ss.ps.lefttree, StreamState)) {
+        ereport(ERROR,
+            (errcode(ERRCODE_FEATURE_NOT_SUPPORTED),
+                errmsg("parallel vector top-K does not support rescan with changed parameters")));
+    }
+    VectorSearchResetResults(node);
+}
