+#!/usr/bin/env bash
+set -euo pipefail
+
+# 00-prepare-env.sh
+# This script prepares the build environment by:
+# 1. Validating and cloning the missing DataInfraLab repositories with retry and integrity checks.
+# 2. Detecting the OS & architecture to download the correct openGauss binarylibs.
+# 3. Downloading with retries and extracting safely to avoid corrupt states.
+# 4. Generating a default opengauss.env file.
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+ICEBERG_OG_DEFAULT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
+export ICEBERG_OG_ROOT="${ICEBERG_OG_ROOT:-$ICEBERG_OG_DEFAULT_ROOT}"
+# GITHUB_BASE can be set externally to override the default repository prefix.
+# If not set, it defaults to the host/path of current origin remote or https://github.com/DataInfraLab.
+
+echo "=================================================="
+echo "Preparing Iceberg openGauss Build Environment"
+echo "Root directory: $ICEBERG_OG_ROOT"
+echo "=================================================="
+
+# Create the root directory if it doesn't exist
+mkdir -p "$ICEBERG_OG_ROOT"
+
+# Helper: Retry a command up to 3 times on failure
+retry_cmd() {
+    local max_attempts=3
+    local attempt=1
+    local delay=5
+    until "$@"; do
+        if (( attempt == max_attempts )); then
+            echo "Error: Command '$*' failed after $max_attempts attempts." >&2
+            return 1
+        fi
+        echo "[WARNING] Command failed. Retrying in $delay seconds (Attempt $attempt/$max_attempts)..."
+        sleep "$delay"
+        (( attempt++ ))
+    done
+}
+
+# Helper: Check disk space (warns if free space is less than 15 GB)
+check_disk_space() {
+    local target_dir="$1"
+    if ! command -v df >/dev/null 2>&1; then
+        return 0
+    fi
+    local avail_kb
+    avail_kb=$(df -Pk "$target_dir" | awk 'NR==2 {print $4}')
+    # 15 GB in KB = 15 * 1024 * 1024 = 15,728,640 KB
+    local required_kb=15728640
+    if [ -n "$avail_kb" ] && [ "$avail_kb" -lt "$required_kb" ]; then
+        local avail_gb=$(( avail_kb / 1024 / 1024 ))
+        echo "[WARNING] Low disk space: Only ${avail_gb}GB available on $target_dir."
+        echo "          Binarylibs download and openGauss compilation may require at least 15GB of free space."
+        echo ""
+    fi
+}
+
+# Pre-requisite checks
+echo "--- Checking system tool requirements ---"
+for tool in git tar awk find; do
+    if ! command -v "$tool" >/dev/null 2>&1; then
+        echo "Error: Required system tool '$tool' is missing. Please install it first." >&2
+        exit 1
+    fi
+done
+echo "[OK] All required system tools are present."
+
+# Check disk space before proceeding
+check_disk_space "$ICEBERG_OG_ROOT"
+
+# 1. Clone missing DataInfraLab repositories
+declare -A REPOS=(
+    ["iceberg-index"]="main"
+    ["iceberg-rust-bridge"]="main"
+    ["iceberg_fdw"]="main"
+    ["openGauss-Catalog"]="main"
+    ["iceberg_delta"]="master"
+)
+
+# Helper: Determine clone URL based on the current origin remote configuration
+get_clone_url() {
+    local repo_name="$1"
+    local origin_url
+    
+    # If GITHUB_BASE was explicitly set by user, honor it.
+    if [ -n "${GITHUB_BASE:-}" ]; then
+        echo "$GITHUB_BASE/$repo_name.git"
+        return
+    fi
+    
+    # Retrieve current repository's origin url
+    origin_url=$(cd "$SCRIPT_DIR" && git config --get remote.origin.url || echo "")
+    
+    if [ -z "$origin_url" ]; then
+        # Default fallback to HTTPS if not a git repo or no origin set
+        echo "https://github.com/DataInfraLab/${repo_name}.git"
+        return
+    fi
+    
+    # Extract protocol and host prefix, then default to cloning from the organization (DataInfraLab)
+    # instead of the user's personal fork, while preserving the protocol/host.
+    if [[ "$origin_url" =~ ^([a-zA-Z0-9+.-]+://[^/]+/|[^@]+@[^:]+:) ]]; then
+        echo "${BASH_REMATCH[1]}DataInfraLab/${repo_name}.git"
+    else
+        # Fallback to default HTTPS DataInfraLab URL
+        echo "https://github.com/DataInfraLab/${repo_name}.git"
+    fi
+}
+
+echo ""
+echo "--- Checking DataInfraLab Repositories ---"
+for repo in "${!REPOS[@]}"; do
+    branch="${REPOS[$repo]}"
+    repo_path="$ICEBERG_OG_ROOT/$repo"
+    
+    # Check repository directory existence and git integrity
+    if [ -d "$repo_path" ]; then
+        if [ -d "$repo_path/.git" ]; then
+            echo "[OK] Repository $repo already exists at $repo_path"
+            continue
+        else
+            echo "[WARNING] Path $repo_path exists but is not a valid git repo. Cleaning up..."
+            rm -rf "$repo_path"
+        fi
+    fi
+
+    CLONE_URL=$(get_clone_url "$repo")
+    echo "[INFO] Cloning $repo (branch: $branch) from $CLONE_URL..."
+    retry_cmd git clone -b "$branch" "$CLONE_URL" "$repo_path"
+done
+
+# 2. Check and generate opengauss.env
+echo ""
+echo "--- Checking opengauss.env ---"
+OPENGAUSS_ENV="$ICEBERG_OG_ROOT/opengauss.env"
+if [ -f "$OPENGAUSS_ENV" ]; then
+    echo "[OK] opengauss.env already exists at $OPENGAUSS_ENV"
+else
+    cat << EOF > "$OPENGAUSS_ENV"
+# Minimal environment configuration for openGauss compilation.
+# Sourced by iceberg-opengauss-build/env.sh.
+
+# Custom GAUSSHOME path (placed at sibling folder of source repository)
+export GAUSSHOME="$ICEBERG_OG_ROOT/mppdb_temp_install"
+EOF
+    echo "[OK] Generated minimal opengauss.env at $OPENGAUSS_ENV"
+fi
+
+# 3. Check and download binarylibs
+echo ""
+echo "--- Checking binarylibs ---"
+BINARYLIBS_DIR="$ICEBERG_OG_ROOT/binarylibs"
+if [ -d "$BINARYLIBS_DIR" ]; then
+    echo "[OK] binarylibs already exists at $BINARYLIBS_DIR"
+else
+    echo "[INFO] binarylibs is missing. Detecting system info for download..."
+    
+    # Detect Architecture
+    ARCH="$(uname -m)"
+    echo "System Architecture: $ARCH"
+    
+    # Detect OS
+    OS_ID=""
+    OS_VERSION_ID=""
+    if [ -f /etc/os-release ]; then
+        . /etc/os-release
+        OS_ID="$ID"
+        OS_VERSION_ID="$VERSION_ID"
+    fi
+    echo "Detected OS: $OS_ID $OS_VERSION_ID"
+    
+    # If the Linux distribution is neither openEuler nor CentOS, ask the user whether to download third-party binarylibs
+    OS_ID_LOWER=$(echo "$OS_ID" | tr '[:upper:]' '[:lower:]')
+    skip_download=false
+    if [[ "$OS_ID_LOWER" != "openeuler" && "$OS_ID_LOWER" != "centos" ]]; then
+        if [ -t 0 ]; then
+            reply=""
+            if read -r -p "Your Linux distribution ($OS_ID) is neither openEuler nor CentOS. Do you want to download third-party binarylibs? [y/N]: " reply; then
+                if [[ ! "$reply" =~ ^[yY](es)?$ ]]; then
+                    skip_download=true
+                fi
+            else
+                skip_download=true
+            fi
+        else
+            echo "[INFO] Non-interactive environment detected. Skipping third-party binarylibs download for unsupported OS."
+            skip_download=true
+        fi
+    fi
+
+    if [ "$skip_download" = "true" ]; then
+        echo "[INFO] Skipped downloading third-party binarylibs."
+    else
+        # Determine the URL based on OS and Architecture
+        URL=""
+        if [[ "$OS_ID" == "openEuler" || "$OS_ID" == "openeuler" ]]; then
+            if [[ "$OS_VERSION_ID" == "24.03" ]]; then
+                if [[ "$ARCH" == "x86_64" ]]; then
+                    URL="https://opengauss.obs.cn-south-1.myhuaweicloud.com/latest/binarylibs/gcc10.3/openGauss-third_party_binarylibs_openEuler_2403_x86_64.tar.gz"
+                elif [[ "$ARCH" == "aarch64" ]]; then
+                    URL="https://opengauss.obs.cn-south-1.myhuaweicloud.com/latest/binarylibs/gcc10.3/openGauss-third_party_binarylibs_openEuler_2403_arm.tar.gz"
+                fi
+            elif [[ "$OS_VERSION_ID" == "22.03" ]]; then
+                if [[ "$ARCH" == "x86_64" ]]; then
+                    URL="https://opengauss.obs.cn-south-1.myhuaweicloud.com/latest/binarylibs/gcc10.3/openGauss-third_party_binarylibs_openEuler_2203_x86_64.tar.gz"
+                elif [[ "$ARCH" == "aarch64" ]]; then
+                    URL="https://opengauss.obs.cn-south-1.myhuaweicloud.com/latest/binarylibs/gcc10.3/openGauss-third_party_binarylibs_openEuler_2203_arm.tar.gz"
+                fi
+            fi
+        fi
+
+        # Fallback to CentOS 7.6 x86_64 if no match or other Linux distro
+        if [ -z "$URL" ]; then
+            echo "[WARNING] No precise OS/Arch binarylibs match found for $OS_ID $OS_VERSION_ID ($ARCH)."
+            if [[ "$ARCH" == "x86_64" ]]; then
+                echo "[INFO] Falling back to default CentOS 7.6 x86_64 binarylibs."
+                URL="https://opengauss.obs.cn-south-1.myhuaweicloud.com/latest/binarylibs/gcc10.3/openGauss-third_party_binarylibs_Centos7.6_x86_64.tar.gz"
+            else
+                echo "Error: Unsupported architecture $ARCH for default binarylibs fallback." >&2
+                exit 1
+            fi
+        fi
+
+        echo "Download URL: $URL"
+        TARBALL_NAME="openGauss-third_party_binarylibs.tar.gz"
+        TARBALL_PATH="$ICEBERG_OG_ROOT/$TARBALL_NAME"
+
+        echo "Downloading binarylibs..."
+        # Perform download with retries
+        if command -v curl >/dev/null 2>&1; then
+            retry_cmd curl -L -C - -o "$TARBALL_PATH" "$URL"
+        elif command -v wget >/dev/null 2>&1; then
+            retry_cmd wget -c -O "$TARBALL_PATH" "$URL"
+        else
+            echo "Error: Neither curl nor wget was found. Please download manually from $URL" >&2
+            exit 1
+        fi
+
+        echo "Extracting binarylibs..."
+        cd "$ICEBERG_OG_ROOT"
+
+        # Use a temp directory for safe extraction (prevents corrupt extraction in root)
+        TMP_EXTRACT_DIR="tmp_binarylibs_extract"
+        rm -rf "$TMP_EXTRACT_DIR"
+        mkdir -p "$TMP_EXTRACT_DIR"
+
+        if ! tar -xf "$TARBALL_NAME" -C "$TMP_EXTRACT_DIR"; then
+            echo "Error: Tar extraction failed. The downloaded tarball may be corrupt. Deleting it..." >&2
+            rm -rf "$TMP_EXTRACT_DIR" "$TARBALL_NAME"
+            exit 1
+        fi
+
+        # Find the extracted folder inside the temp folder and move it to final destination
+        EXTRACTED_SUB=$(find "$TMP_EXTRACT_DIR" -maxdepth 1 -type d ! -name "$TMP_EXTRACT_DIR" | head -n 1)
+        if [ -n "$EXTRACTED_SUB" ]; then
+            mv "$EXTRACTED_SUB" binarylibs
+            rm -rf "$TMP_EXTRACT_DIR"
+            echo "[OK] binarylibs extracted and renamed to $BINARYLIBS_DIR"
+
+            # Check sha256sum of the downloaded tarball to fix known symlink issue
+            if command -v sha256sum >/dev/null 2>&1; then
+                file_hash=$(sha256sum "$TARBALL_NAME" | awk '{print $1}')
+                if [ "$file_hash" = "1d95de0783062697479bb9fcb598631e3c1c847bb40adff113ab63247b072146" ]; then
+                    echo -e "\033[1;33m[INFO] Detected binarylibs with known onnxruntime symlink mismatch. Fixing symlinks...\033[0m"
+                    onnx_lib_dir="binarylibs/kernel/dependency/onnxruntime/comm/lib"
+                    if [ -d "$onnx_lib_dir" ]; then
+                        (
+                            cd "$onnx_lib_dir"
+                            ln -sf libonnxruntime.so.1.22.0 libonnxruntime.so.1
+                            ln -sf libonnxruntime.so.1 libonnxruntime.so
+                            echo -e "\033[1;32m[OK] Fixed onnxruntime symlinks to point to libonnxruntime.so.1.22.0\033[0m"
+                        )
+                    else
+                        echo -e "\033[1;31m[WARNING] onnxruntime lib directory not found at $onnx_lib_dir\033[0m" >&2
+                    fi
+                fi
+            else
+                echo -e "\033[1;31m[WARNING] sha256sum command not found, skipping hash verification.\033[0m" >&2
+            fi
+        else
+            echo "Error: Could not locate extracted directory structure." >&2
+            rm -rf "$TMP_EXTRACT_DIR"
+            exit 1
+        fi
+
+        # Clean up the downloaded tarball
+        rm -f "$TARBALL_NAME"
+        echo "[INFO] Cleaned up tarball file."
+    fi
+fi
+
+# 4. Check and install Rust toolchain (1.96)
+echo ""
+echo -e "\033[1;36m--- Checking Rust toolchain (1.96) ---\033[0m"
+
+# Print mirror env info if set
+if [ -n "${RUSTUP_DIST_SERVER:-}" ]; then
+    echo -e "\033[1;36m[INFO] Custom RUSTUP_DIST_SERVER detected: $RUSTUP_DIST_SERVER\033[0m"
+fi
+if [ -n "${RUSTUP_UPDATE_ROOT:-}" ]; then
+    echo -e "\033[1;36m[INFO] Custom RUSTUP_UPDATE_ROOT detected: $RUSTUP_UPDATE_ROOT\033[0m"
+fi
+
+# Source cargo env in current session if exists to avoid false-negatives
+if [ -f "$HOME/.cargo/env" ]; then
+    # shellcheck disable=SC1091
+    source "$HOME/.cargo/env"
+fi
+
+# Robust health check: Check if rustc and cargo both exist AND can execute successfully
+rust_healthy=false
+CURRENT_RUST_VERSION=""
+if command -v rustc >/dev/null 2>&1 && command -v cargo >/dev/null 2>&1; then
+    # Run rustc in an 'if' condition to safely catch non-zero exit codes under 'set -e'
+    if CURRENT_RUST_VERSION=$(rustc --version 2>/dev/null | awk '{print $2}') && [ -n "$CURRENT_RUST_VERSION" ]; then
+        rust_healthy=true
+    fi
+fi
+
+if [ "$rust_healthy" = true ]; then
+    echo -e "\033[1;36m[INFO] Found active Rust version: $CURRENT_RUST_VERSION\033[0m"
+    if [[ "$CURRENT_RUST_VERSION" != 1.96* ]]; then
+        if command -v rustup >/dev/null 2>&1; then
+            echo -e "\033[1;33m[WARNING] Rust version is not 1.96. Installing and setting default to 1.96 via rustup...\033[0m"
+            rustup toolchain install 1.96
+            rustup default 1.96
+            echo -e "\033[1;32m[OK] Rust toolchain switched to 1.96.\033[0m"
+        else
+            echo -e "\033[1;33m[WARNING] Rust version is $CURRENT_RUST_VERSION (not 1.96), and rustup is not installed.\033[0m" >&2
+            echo -e "\033[1;33m          Compilation of Rust components may fail. Please ensure Rust 1.96+ is used.\033[0m" >&2
+        fi
+    else
+        echo -e "\033[1;32m[OK] Rust toolchain 1.96 is already active.\033[0m"
+    fi
+else
+    # Rust is not healthy: Either completely missing, or shims exist but toolchain is missing/corrupted
+    if command -v rustup >/dev/null 2>&1; then
+        echo -e "\033[1;33m[WARNING] Rust shims found but toolchain is missing/broken (semi-installed state).\033[0m"
+        echo -e "\033[1;36m[INFO] Attempting to auto-repair by installing Rust 1.96 toolchain via rustup...\033[0m"
+        if rustup toolchain install 1.96 && rustup default 1.96; then
+            echo -e "\033[1;32m[OK] Rust 1.96 toolchain repaired and configured successfully.\033[0m"
+        else
+            echo -e "\033[1;31m[ERROR] Rust toolchain repair failed. Please check network/mirror settings.\033[0m" >&2
+            exit 1
+        fi
+    else
+        echo -e "\033[1;36m[INFO] Rust toolchain is missing. Installing rustup and Rust 1.96...\033[0m"
+        if command -v curl >/dev/null 2>&1; then
+            # Silent install with -y, default toolchain 1.96
+            if curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.96; then
+                # Load environment
+                if [ -f "$HOME/.cargo/env" ]; then
+                    # shellcheck disable=SC1091
+                    source "$HOME/.cargo/env"
+                fi
+                echo -e "\033[1;32m[OK] Rust 1.96 toolchain installed successfully.\033[0m"
+            else
+                echo -e "\033[1;31m[ERROR] Rust installation failed.\033[0m" >&2
+                exit 1
+            fi
+        else
+            echo -e "\033[1;31m[ERROR] curl is required to install rustup. Please install curl first.\033[0m" >&2
+            exit 1
+        fi
+    fi
+fi
+
+echo ""
+echo "=================================================="
+echo "[OK] Preparation complete! Environment is ready."
+echo "=================================================="
diff --git a/iceberg-opengauss-build/01-build-opengauss.sh b/iceberg-opengauss-build/01-build-opengauss.sh
new file mode 100755
index 0000000000000000000000000000000000000000..fd1a7118588b59fe5cdf0298be41359c3ab9f1a1
--- /dev/null
+++ b/iceberg-opengauss-build/01-build-opengauss.sh
@@ -0,0 +1,155 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+# shellcheck disable=SC1091
+source "$SCRIPT_DIR/env.sh"
+
+echo -e "\033[1;36m=== Stage 1: Validating paths and compilers ===\033[0m"
+require_common_paths
+require_executable "$OPENGAUSS_CC"
+require_executable "$OPENGAUSS_CXX"
+ensure_python_shim
+load_opengauss_env
+
+cd "$OPENGAUSS_REPO"
+make_install_tree_writable
+
+echo -e "\033[1;36m=== Stage 2: Compiling openGauss ===\033[0m"
+
+CPU_CORES=1
+if command -v nproc >/dev/null 2>&1; then
+    CPU_CORES=$(( $(nproc) / 2 ))
+fi
+[ "$CPU_CORES" -lt 1 ] && CPU_CORES=1
+BUILD_JOBS="${BUILD_JOBS:-$CPU_CORES}"
+INSTALL_JOBS="${INSTALL_JOBS:-$BUILD_JOBS}"
+OPENGAUSS_BUILD_MODE="${OPENGAUSS_BUILD_MODE:-source-install}"
+OPENGAUSS_GCC_VERSION="${OPENGAUSS_GCC_VERSION:-$("$OPENGAUSS_CXX" -dumpfullversion -dumpversion)}"
+OPENGAUSS_CFLAGS="${OPENGAUSS_CFLAGS:--O0}"
+
+mkdir -p "$ICEBERG_OG_LOG_DIR"
+BUILD_LOG_FILE="${OPENGAUSS_BUILD_LOG_FILE:-$ICEBERG_OG_LOG_DIR/$(date +%Y%m%d-%H%M%S)-opengauss-$OPENGAUSS_BUILD_MODE.log}"
+echo -e "\033[1;32m[INFO] Logs will be saved to: $BUILD_LOG_FILE\033[0m"
+
+if ! declare -p OPENGAUSS_EXTRA_CONFIG_OPTS >/dev/null 2>&1; then
+    if [ "${OPENGAUSS_EXTRA_CONFIG_OPT:-}" ]; then
+        # Backward-compatible simple flag list. Use OPENGAUSS_EXTRA_CONFIG_OPTS
+        # in local.env for arguments that require precise quoting.
+        read -r -a OPENGAUSS_EXTRA_CONFIG_OPTS <<< "$OPENGAUSS_EXTRA_CONFIG_OPT"
+    else
+        OPENGAUSS_EXTRA_CONFIG_OPTS=(--enable-mot --enable-bbox --enable-htap)
+    fi
+fi
+
+normalize_path() {
+    if command -v realpath >/dev/null 2>&1; then
+        realpath -m "$1"
+    else
+        echo "$1"
+    fi
+}
+
+run_source_install() {
+    echo "[INFO] Compiling openGauss from source and installing to GAUSSHOME=$GAUSSHOME"
+    echo "[INFO] BUILD_JOBS=$BUILD_JOBS INSTALL_JOBS=$INSTALL_JOBS"
+    echo "[INFO] OPENGAUSS_GCC_VERSION=$OPENGAUSS_GCC_VERSION"
+    echo "[INFO] OPENGAUSS_CXX=$OPENGAUSS_CXX"
+
+    if [ -f Makefile ]; then
+        make distclean -sj || true
+    fi
+
+    local -a configure_args=(
+        --gcc-version="$OPENGAUSS_GCC_VERSION"
+        --prefix="$GAUSSHOME"
+        --3rd="$BINARYLIBS_DIR"
+        --enable-debug
+        --enable-cassert
+        --enable-thread-safety
+        --with-readline
+        --without-zlib
+        CC="$OPENGAUSS_CXX"
+        CFLAGS="$OPENGAUSS_CFLAGS"
+        "${OPENGAUSS_EXTRA_CONFIG_OPTS[@]}"
+    )
+
+    ./configure "${configure_args[@]}"
+
+    make -sj "$BUILD_JOBS"
+    make install -sj "$INSTALL_JOBS"
+}
+
+run_build_sh() {
+    local build_sh_install_dir
+    build_sh_install_dir="$OPENGAUSS_REPO/mppdb_temp_install"
+
+    if [ "$(normalize_path "$GAUSSHOME")" != "$(normalize_path "$build_sh_install_dir")" ]; then
+        echo "Error: OPENGAUSS_BUILD_MODE=build-sh installs to $build_sh_install_dir," >&2
+        echo "but GAUSSHOME is $GAUSSHOME." >&2
+        echo "Use OPENGAUSS_BUILD_MODE=source-install for a custom GAUSSHOME, or set" >&2
+        echo "GAUSSHOME=$build_sh_install_dir when intentionally using build.sh compatibility mode." >&2
+        return 1
+    fi
+
+    echo "[INFO] Compiling openGauss with build.sh..."
+    sh build.sh -m debug -3rd "$BINARYLIBS_DIR"
+}
+
+run_stage2() {
+    case "$OPENGAUSS_BUILD_MODE" in
+        source-install)
+            run_source_install
+            ;;
+        build-sh)
+            run_build_sh
+            ;;
+        custom-hook)
+            if ! declare -F og_build_install_debug >/dev/null; then
+                echo "Error: OPENGAUSS_BUILD_MODE=custom-hook but og_build_install_debug is not defined" >&2
+                return 1
+            fi
+            echo "[INFO] Running custom og_build_install_debug hook..."
+            og_build_install_debug "$OPENGAUSS_REPO" "$BINARYLIBS_DIR"
+            ;;
+        *)
+            echo "Error: unknown OPENGAUSS_BUILD_MODE=$OPENGAUSS_BUILD_MODE" >&2
+            echo "Expected one of: source-install, build-sh, custom-hook" >&2
+            return 2
+            ;;
+    esac
+}
+
+if run_stage2 >"$BUILD_LOG_FILE" 2>&1; then
+    :
+else
+    rc=$?
+    echo "Error: openGauss build failed with exit code $rc" >&2
+    echo "Full log: $BUILD_LOG_FILE" >&2
+    echo "Failure excerpt:" >&2
+    iceberg_og_log_excerpt "$BUILD_LOG_FILE"
+    exit "$rc"
+fi
+
+echo -e "\033[1;36m=== Stage 3: Verifying openGauss installation ===\033[0m"
+if [ ! -x "$GAUSSHOME/bin/pg_config" ]; then
+    echo "Error: pg_config not found or not executable at $GAUSSHOME/bin/pg_config" >&2
+    exit 1
+fi
+if [ ! -x "$GAUSSHOME/bin/gsql" ]; then
+    echo "Error: gsql not found or not executable at $GAUSSHOME/bin/gsql" >&2
+    exit 1
+fi
+if [ ! -x "$GAUSSHOME/bin/gaussdb" ]; then
+    echo "Error: gaussdb not found or not executable at $GAUSSHOME/bin/gaussdb" >&2
+    exit 1
+fi
+
+echo "Installed pg_config version:"
+"$GAUSSHOME/bin/pg_config" --version
+echo "Installed gsql version:"
+"$GAUSSHOME/bin/gsql" --version
+
+echo "=================================================="
+echo -e "\033[1;32m[OK] openGauss build/install verified: $GAUSSHOME\033[0m"
+echo "=================================================="
