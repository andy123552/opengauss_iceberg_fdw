+     * Sort column confirmed as a supported vector distance; only now reshape the
+     * plan. make_sort_from_pathkeys skipped the LOCAL GATHER because the LIMIT
+     * count fits the per-worker estimate, so insert it here and rebuild the Sort
+     * proxy over the gathered dop-1 input. Rebuilding re-costs the sort against
+     * the real VectorSearch shape (input cost now covers the gather, DOP drops to
+     * 1); copying the stale dop>1 cost onto VectorSearch would misprice EXPLAIN,
+     * cached plan selection and resource tracking.
+     */
+    if (need_local_gather) {
+        lefttree = create_local_gather(lefttree);
+        sortPlan = make_sort_from_pathkeys(root, lefttree, root->sort_pathkeys, limitTuples);
+        lefttree = sortPlan->plan.lefttree;
+    }
+
+    fetchK = vectorsearch_compute_fetch_k(topK);
+
+    node = makeNode(VectorSearch);
+    plan = &node->plan;
+
+    copy_plan_costsize(plan, (Plan*)sortPlan);
+    plan->targetlist = sortPlan->plan.targetlist;
+    plan->qual = NIL;
+    plan->lefttree = lefttree;
+    plan->righttree = NULL;
+    plan->hasUniqueResults = sortPlan->plan.hasUniqueResults;
+    plan->dop = sortPlan->plan.dop;
+    /*
+     * Inherit exec_nodes/exec_type/distributed_keys from the child, matching what
+     * make_sort sets on the Sort this node replaces. Without it exec_nodes stays
+     * NULL; a parallel plan then dereferences it in BuildStreamFlow (SetCheckInfo)
+     * at executor start and crashes. Serial plans never build the stream flow, so
+     * the gap only surfaces under a LOCAL GATHER child.
+     */
+    inherit_plan_locator_info(plan, lefttree);
+
+    node->numCols = sortPlan->numCols;
+    node->sortColIdx = (AttrNumber*)palloc(sizeof(AttrNumber) * sortPlan->numCols);
+    node->sortOperators = (Oid*)palloc(sizeof(Oid) * sortPlan->numCols);
+    node->collations = (Oid*)palloc(sizeof(Oid) * sortPlan->numCols);
+    node->nullsFirst = (bool*)palloc(sizeof(bool) * sortPlan->numCols);
+    errno_t rc = memcpy_s(node->sortColIdx, sizeof(AttrNumber) * sortPlan->numCols,
+        sortPlan->sortColIdx, sizeof(AttrNumber) * sortPlan->numCols);
+    securec_check(rc, "\0", "\0");
+    rc = memcpy_s(node->sortOperators, sizeof(Oid) * sortPlan->numCols,
