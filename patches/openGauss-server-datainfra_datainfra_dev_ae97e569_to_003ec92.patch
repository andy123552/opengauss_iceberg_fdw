+    securec_check(rc, "\0", "\0");
+
+    node->topK = topK;
+    node->fetchK = fetchK;
+    node->algorithm = VECTORSEARCH_ALGO_TOPK;
+    node->metric = VECTORSEARCH_METRIC_L2;
+
+    return (Plan*)node;
+}
